<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reise-Globus</title>
    <link rel="stylesheet" href="style.css">
    <script src="https://maps.googleapis.com/maps/api/js?key=API_KEY&libraries=places"></script>
</head>
<body>
    <header>
        <h1>Meine Reisen</h1>
    </header>

    <main>
        <div id="map"></div>
        <div id="album">
            <div class="album-header">
                <h2>Fotos von <span id="location-name"></span></h2>
            </div>
            <div class="album-photos" id="photo-container">
                <!-- Fotos werden dynamisch hier eingefügt -->
            </div>
        </div>
    </main>

    <script src="script.js"></script>
</body>
</html>